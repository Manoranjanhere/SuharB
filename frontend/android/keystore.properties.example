## Copy to keystore.properties (gitignored) and fill in your upload keystore details.
## The keystore SHA-1 must match Firebase / google-services.json:
##   3c:92:5f:c4:a0:50:ec:e7:de:6b:45:eb:e5:25:ed:0d:bd:e3:12:17
##
## Place the keystore file at: android/app/sugarbf.keystore

storeFile=sugarbf.keystore
storePassword=your_store_password
keyAlias=your_key_alias
keyPassword=your_key_password
