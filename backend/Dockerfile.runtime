# Fast image when dist/ already exists (run npm ci && npm run build first).
# docker compose build --build-arg DOCKERFILE=Dockerfile.runtime

FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

COPY package.json package-lock.json ./
RUN npm ci --omit=dev --no-audit --no-fund

COPY dist ./dist

EXPOSE 3000

CMD ["node", "dist/main.js"]
