# Use this file on YOUR LAPTOP to run migrations/seeds against AWS RDS.
# Copy to:  backend/.env.production.local   (gitignored — do not commit)
#
# Requires: your public IP allowed in RDS security group (port 5432)

NODE_ENV=production
PORT=3000

# ⚠️ Set false when testing real subscriptions/coins on prod API
DISABLE_PAID_FEATURES=false

# Aurora / RDS writer endpoint
DB_HOST=database-1.cluster-chsuw4a8mjnh.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=YOUR_RDS_MASTER_PASSWORD
DB_NAME=postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

# Copy JWT, Firebase, AWS S3, Google Play JSON from EC2 .env.production if you also run API locally against prod DB
JWT_SECRET=your_production_jwt_secret
JWT_EXPIRES_IN=30d

FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=sugarbf

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=sugarbf-photos

GOOGLE_PLAY_PACKAGE_NAME=com.sugarbf.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_SKIP_VERIFY=false

# Optional: seed script locality (defaults to Rourkela)
# SEED_CITY=Rourkela
# SEED_LAT=22.2604
# SEED_LNG=84.8536
