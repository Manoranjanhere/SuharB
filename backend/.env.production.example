# Copy to .env.production on the server (see .env.production for full template with Aurora DB)

NODE_ENV=production
PORT=3000
DISABLE_PAID_FEATURES=true

# Aurora PostgreSQL (ap-south-1) — API uses writer endpoint
DB_HOST=database-1.chsuw4a8mjnh.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_rds_master_password
DB_NAME=sugarbf
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

# Copy remaining vars from your local .env (JWT, Firebase, AWS, etc.)
