{
  "name": "sb-backend",
  "version": "1.0.0",
  "description": "SugarBf backend - NestJS",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "seed:test-users": "node scripts/seed-test-users.js",
    "seed:noida:prod": "node scripts/seed-test-users.js --prod",
    "seed:prod:all": "node scripts/run-seed-prod-all.js",
    "seed:rourkela": "node scripts/seed-rourkela-users.js",
    "seed:rourkela:prod": "node scripts/seed-rourkela-users.js --prod",
    "migration:run:prod": "node scripts/run-migrations.js --prod --confirm-prod",
    "db:ping": "node scripts/db-ping.js",
    "db:ping:prod": "node scripts/db-ping.js --prod",
    "migration:generate": "typeorm-ts-node-commonjs -d src/config/typeorm.data-source.ts migration:generate src/migrations/AutoMigration",
    "migration:run": "typeorm-ts-node-commonjs -d src/config/typeorm.data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/config/typeorm.data-source.ts migration:revert"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.22",
    "apple-signin-auth": "^1.7.3",
    "aws-sdk": "^2.1564.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^9.7.0",
    "googleapis": "^173.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-facebook-token": "^4.0.0",
    "passport-google-token": "^0.1.2",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.4.22",
    "@swc/cli": "^0.3.12",
    "@swc/core": "^1.7.26",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
