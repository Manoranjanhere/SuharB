# App
PORT=3000
NODE_ENV=development
DISABLE_PAID_FEATURES=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=yourpassword
DB_NAME=sugarbf
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=30d

# Firebase (phone OTP SMS on mobile + push notifications)
# Web OAuth client (type 3 in google-services.json) — used for idToken verification
GOOGLE_CLIENT_ID=887817604127-62iml2nfpdmcfl5b100riok8iepuo58l.apps.googleusercontent.com
# Android OAuth client (type 1) — optional; also accepted when verifying tokens
GOOGLE_ANDROID_CLIENT_ID=887817604127-mlu4ekvrjufocnnbgq1e6ekjanapmk84.apps.googleusercontent.com

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Apple Sign In
APPLE_CLIENT_ID=com.yourcompany.sugarbf

# Firebase Admin (verify phone OTP tokens + push notifications)
# Easiest: download service account JSON from Firebase Console → paste as one line below.
# Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=sugarbf
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Gmail (Nodemailer)
GMAIL_USER=your.admin@gmail.com
GMAIL_APP_PASSWORD=your_google_app_password_16chars

# App URLs
APP_DEEP_LINK=sugarbf
WEB_BASE_URL=https://sugarbfapp.com
ADMIN_WEB_URL=https://admin.sugarbfapp.com
PRIVACY_URL=https://sugarbf.club/privacy
TERMS_URL=https://sugarbf.club/terms
SUPPORT_URL=https://sugarbf.club/support

# Google Play Billing (required for in-app subscriptions on Android)
GOOGLE_PLAY_PACKAGE_NAME=com.sugarbf.app
# Service account JSON with Android Publisher API access (same file as Firebase is OK if granted Play Console access)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Dev only: skip Play API verify when DISABLE_PAID_FEATURES=true
GOOGLE_PLAY_SKIP_VERIFY=false

# Stripe (legacy — mobile app uses Google Play)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AWS S3 (photo storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=sugarbf-photos
